# Supabase cloud sync (optional)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: override table name if you use a custom one
VITE_SUPABASE_SYNC_TABLE=knapsack_user_data

# Optional: Google Identity Services web client ID (fallback button / direct web login)
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Optional: email activation redirect target (defaults to <site-origin>/landing)
VITE_SUPABASE_AUTH_REDIRECT_TO=https://your-app-domain/landing

# Optional: Supabase table that stores paid/free subscription state
VITE_SUPABASE_PREMIUM_TABLE=knapsack_user_subscriptions

# Premium access control fallback (comma-separated, only for emergencies/manual overrides)
VITE_PREMIUM_EMAILS=
VITE_PREMIUM_GOOGLE_IDS=

# Optional: public upgrade/paywall URL shown to free users
VITE_PREMIUM_UPGRADE_URL=

# Emergency switch: set true to stop all cloud sync traffic immediately
VITE_DISABLE_CLOUD_SYNC=false

# Security: Disable new user signups (rate-limit abuse)
# Set VITE_DISABLE_SIGNUP=true to block new registrations for real emails
# Note: @knapsack.local test emails always work, unaffected by this setting
VITE_DISABLE_SIGNUP=false

# Security: Client-side auth rate limiting
# Set VITE_DISABLE_AUTH_RATE_LIMIT=true to turn off rate limiting (not recommended)
VITE_DISABLE_AUTH_RATE_LIMIT=false

# Max failed login/register attempts per email before rate limit kicks in (default: 8)
VITE_AUTH_MAX_ATTEMPTS=8

# Time window in seconds for rate limit reset per email (default: 900 = 15 minutes)
VITE_AUTH_RATE_LIMIT_WINDOW_SECONDS=900
